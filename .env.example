# 공통
TZ=Asia/Seoul
DATABASE_PATH=data/openchat.db
RETENTION_RAW_DAYS=7

# 수집
COLLECT_INTERVAL_MINUTES=60
MIN_DISTINCT_NICKS=3
# 프로젝트 설정 (projects.yaml 우선; 없으면 rooms.yaml)
# PROJECTS_CONFIG=config/projects.yaml
ROOMS_CONFIG=config/rooms.yaml

# Web UI — docs/web-service-guide.md
# SERVE_HOST=0.0.0.0
# SERVE_PORT=8000
# UI_SETTINGS_CONFIG=config/ui_settings.yaml
# EMAIL_API_BASE_URL=http://10.246.42.51:8000
# SERVE_PUBLIC_BASE_URL=http://10.0.0.1:8000
CAPTURES_DIR=captures
STATE_DIR=data/state

# 분석 (Periodic Analyzer) — EXAONE 3.5 7.8B Instruct, GGUF 4-bit Q4_K_M
# https://huggingface.co/LGAI-EXAONE/EXAONE-3.5-7.8B-Instruct-GGUF
# Ollama: ollama run hf.co/LGAI-EXAONE/EXAONE-3.5-7.8B-Instruct-GGUF  (기본 quant = Q4_K_M)
ANALYZER_PROVIDER=openai
OPENAI_API_BASE=http://localhost:11434/v1
ANALYZER_MODEL=EXAONE-3.5-7.8B-Instruct
ANALYZER_QUANTIZATION=Q4_K_M
ANALYZER_GGUF_REPO=LGAI-EXAONE/EXAONE-3.5-7.8B-Instruct-GGUF
ANALYZER_API_KEY=ollama
ANALYZER_PERIOD=1d
ANALYZER_PROMPT_VERSION=v1
ANALYZER_USE_LLM=true
ANALYZER_FALLBACK_HEURISTIC=false
# ANALYZER_MAX_TRANSCRIPT_CHARS=8000
# ANALYZER_TEMPERATURE=0.2
# ANALYZER_TIMEOUT_SECONDS=180

# 리포트 합성 (Reporter LLM) — OpenAI 공식 API 전용 (Analyzer/Ollama와 분리)
REPORTER_PROVIDER=openai
REPORTER_MODEL=gpt-5.2
REPORTER_API_KEY=sk-...
REPORTER_OPENAI_API_BASE=https://api.openai.com/v1
# REPORTER_USE_LLM=false
# REPORTER_FALLBACK_STATIC=true
# REPORTER_WEB_SEARCH=true
# REPORTER_MAX_TOPICS=20
# REPORTER_MAX_PATCH_REACTIONS=15
# REPORTER_CONTEXT_CHARS=6000
# REPORTER_TEMPERATURE=0.3
# REPORTER_TIMEOUT_SECONDS=300
# REPORTER_UPDATE_NOTES_MAX_PAGES=8
# REPORTER_FETCH_TIMEOUT_SECONDS=45
REPORTER_WINDOW=7d

# Periodic Analyzer(EXAONE)용 — Reporter 리포트는 rooms.yaml update_notes_url 사용
PATCHNOTES_PATH=docs/patchnotes.md
ROADMAP_PATH=docs/roadmap.md
OUTPUT_DIR=reports
